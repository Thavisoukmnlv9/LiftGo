# Node.js / TypeScript monorepo ignores
node_modules/
**/node_modules/
dist/
build/
out/
.next/
.nuxt/
.svelte-kit/
.turbo/
.vercel/
.cache/
.parcel-cache/
.eslintcache
coverage/
storybook-static/

# Package manager locks (allow one if you standardize)
package-lock.json
yarn.lock
pnpm-lock.yaml
bun.lockb

# Environment and secrets
.env
.env.*
**/.env
**/.env.*
.env.local
.env.test
.env.production
.env.development

# OS / Editor
.DS_Store
Thumbs.db
*.swp
*.swo
.idea/
.vscode/
*.iml

# Logs / diagnostics
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Typescript
*.tsbuildinfo

# Misc build artifacts
*.pid
*.seed
*.tgz

# Images/build outputs generated during dev
apps/public/*.map

# Optional: lockfile backups
*.orig

